{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "simautomate5",
  "version": "0.1.2",
  "identifier": "v5.simautomate.dedalus",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SimAutomateV5",
        "width": 800,
        "height": 600,
        "minWidth": 700,
        "minHeight": 450
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
